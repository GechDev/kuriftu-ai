generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())

  bookings         Booking[]
  serviceRequests  ServiceRequest[]
  notifications    Notification[]
}

model Resort {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  region           String
  shortDescription String
  fullDescription  String?
  address          String
  /// Voice-friendly overview of the property layout and how to get around.
  mapOverview      String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  rooms     Room[]
  services  ResortService[]
  mapPlaces MapPlace[]
}

/// On-property offerings: spa, dining, pools, activities, concierge, etc.
model ResortService {
  id           String  @id @default(cuid())
  resortId     String
  /// e.g. dining, spa, pool, fitness, kids, concierge, transport, in_room, wellness, activities
  category     String
  title        String
  description  String
  hours        String?
  locationNote String?
  howToBook    String?

  resort Resort @relation(fields: [resortId], references: [id], onDelete: Cascade)

  @@index([resortId])
  @@index([resortId, category])
}

/// Walkable destinations for directions and “where is …?”
model MapPlace {
  id                  String  @id @default(cuid())
  resortId            String
  name                String
  /// e.g. lobby, restaurant, spa, pool, parking, gym, shop, room_tower, landmark
  category            String
  building            String?
  floor               String?
  directionsFromLobby String

  resort Resort @relation(fields: [resortId], references: [id], onDelete: Cascade)

  @@index([resortId])
  @@index([resortId, category])
}

model Room {
  id             String   @id @default(cuid())
  name           String
  description    String?
  pricePerNight  Int
  resortId       String?
  createdAt      DateTime @default(now())

  resort          Resort?         @relation(fields: [resortId], references: [id], onDelete: SetNull)
  bookings        Booking[]
  serviceRequests ServiceRequest[]

  @@index([resortId])
}

model Booking {
  id           String    @id @default(cuid())
  userId       String
  roomId       String
  checkIn      DateTime
  checkOut     DateTime
  totalPrice   Int
  checkedInAt  DateTime?
  checkedOutAt DateTime?
  createdAt    DateTime  @default(now())

  user  User @relation(fields: [userId], references: [id], onDelete: Cascade)
  room  Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  serviceRequests ServiceRequest[]

  @@index([roomId])
  @@index([userId])
}

enum ServiceRequestStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

model ServiceRequest {
  id        String               @id @default(cuid())
  userId    String
  roomId    String
  bookingId String?
  message   String
  /// housekeeping, dining, spa, maintenance, transport, concierge, other
  serviceCategory String?
  status    ServiceRequestStatus @default(PENDING)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  room    Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}
